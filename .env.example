# =============================================================================
# Network Supervision - Environment Configuration
# =============================================================================
# Copy this file to .env and adjust values for your environment.

# Application
APP_NAME=network-supervisor
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO

# PostgreSQL
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=supervisor
POSTGRES_PASSWORD=supervisor_dev_password
POSTGRES_DB=network_supervisor

# Scheduler
SCHEDULER_ENABLED=true
PING_INTERVAL_SECONDS=30
SNMP_INTERVAL_SECONDS=60
POWER_INTERVAL_SECONDS=30

# Anti-flapping — pings ratés consécutifs avant d'ouvrir un incident DOWN
PING_DOWN_THRESHOLD=3

# Sonde de transit — vérifie que le trafic traverse le lien radio LTU LR ↔ LTU Rocket
# Au moins une IP doit répondre pour valider le transit
TRANSIT_PROBE_IPS=1.1.1.1,8.8.8.8
TRANSIT_PROBE_INTERVAL=60
TRANSIT_PROBE_THRESHOLD=2

# Notifications — Webhook (laisser vide pour désactiver)
WEBHOOK_URL=
SLACK_WEBHOOK_URL=

# Notifications — WhatsApp via WhatChimp (Webhook Workflow)
# Mettre à true pour logger les payloads sans envoyer (test de configuration)
WHATSAPP_TEST_MODE=false

# Notifications — Email SMTP
SMTP_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=votre@email.com
SMTP_PASSWORD=mot_de_passe_application
SMTP_FROM_EMAIL=supervision@company.com
SMTP_FROM_NAME=Network Supervisor
SMTP_USE_TLS=true
SMTP_USE_SSL=false
# Destinataires séparés par une virgule
NOTIFICATION_EMAILS=admin@company.com,ops@company.com

# SNMP — Ubiquiti airMAX / LTU
SNMP_DEFAULT_COMMUNITY=public
SNMP_PORT=161
SNMP_TIMEOUT=2

# UISP Power — API locale du device
UISP_POWER_USERNAME=ubnt
UISP_POWER_PASSWORD=ubnt
UISP_POWER_PORT=80

# Seuils d'anomalie — lien radio (LTU Rocket / LTU LR)
SIGNAL_WARNING_DBM=-70
SIGNAL_CRITICAL_DBM=-80
CCQ_WARNING_PCT=75
CCQ_CRITICAL_PCT=50

# Seuils d'anomalie — UISP Power (batterie)
BATTERY_WARNING_PCT=25
BATTERY_CRITICAL_PCT=10
