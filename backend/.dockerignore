# Réduit le contexte de build envoyé au démon Docker et évite d'invalider le
# cache de layers (COPY . .) avec des fichiers locaux non versionnés.

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
dist/
build/

# Virtual environments
.venv/
venv/
env/

# Outils / cache
.ruff_cache/
.pytest_cache/
.mypy_cache/
.coverage
htmlcov/

# Secrets / env (fournis au runtime via env_file, jamais cuits dans l'image)
.env
*.env.local

# Divers
*.log
.git/
.gitignore
.DS_Store
Thumbs.db
