# =============================================================================
# Network Supervisor — Environment Configuration
# =============================================================================
# Copie ce fichier en .env et adapte les valeurs.
# Toutes les variables sont chargées par backend/app/core/config.py.

# ─────────────────────────────────────────────────────────────────────────────
# Application
# ─────────────────────────────────────────────────────────────────────────────
APP_NAME=network-supervisor
APP_ENV=development          # development | production
DEBUG=true
LOG_LEVEL=INFO

# Authentification API — clé partagée entre backend et frontend (header X-API-Key).
# OBLIGATOIRE en production : le backend refuse de démarrer si vide quand APP_ENV=production.
API_KEY=

# CORS — origines séparées par une virgule (laisser vide = pas de CORS)
CORS_ORIGINS=http://localhost:3000

# ─────────────────────────────────────────────────────────────────────────────
# PostgreSQL
# ─────────────────────────────────────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=supervisor
POSTGRES_PASSWORD=supervisor_dev_password
POSTGRES_DB=network_supervisor

# Pool SQLAlchemy — à dimensionner selon la concurrence attendue
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10

# ─────────────────────────────────────────────────────────────────────────────
# Scheduler & polling
# ─────────────────────────────────────────────────────────────────────────────
SCHEDULER_ENABLED=true
PING_INTERVAL_SECONDS=30
SNMP_INTERVAL_SECONDS=60
POWER_INTERVAL_SECONDS=30

# Digest — regroupement des warnings (minutes)
WARNING_DIGEST_MINUTES=15

# ─────────────────────────────────────────────────────────────────────────────
# Anti-flapping & latence ping
# ─────────────────────────────────────────────────────────────────────────────
# Pings consécutifs ratés avant d'ouvrir un incident DOWN
PING_DOWN_THRESHOLD=3

# Instabilité ping : N échecs suivis d'un succès → email INFO. 0 = désactivé.
PING_INSTABILITY_THRESHOLD=2

# Latence ping (ms)
PING_LATENCY_WARN_MS=100
PING_LATENCY_CRIT_MS=300
PING_LATENCY_FAILURE_THRESHOLD=3

# ─────────────────────────────────────────────────────────────────────────────
# Sonde de transit (LTU LR → internet via SSH)
# ─────────────────────────────────────────────────────────────────────────────
TRANSIT_PROBE_ENABLED=true
TRANSIT_PROBE_IPS=1.1.1.1,8.8.8.8
TRANSIT_PROBE_INTERVAL=60
TRANSIT_PROBE_THRESHOLD=2

# ─────────────────────────────────────────────────────────────────────────────
# Notifications — Email SMTP
# ─────────────────────────────────────────────────────────────────────────────
SMTP_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=votre@email.com
SMTP_PASSWORD=mot_de_passe_application
SMTP_FROM_EMAIL=supervision@company.com
SMTP_FROM_NAME=Network Supervisor
SMTP_USE_TLS=true            # STARTTLS (port 587)
SMTP_USE_SSL=false           # SSL direct (port 465)
# Destinataires séparés par une virgule
NOTIFICATION_EMAILS=admin@company.com,ops@company.com

# ─────────────────────────────────────────────────────────────────────────────
# SNMP (Ubiquiti airMAX / LTU)
# ─────────────────────────────────────────────────────────────────────────────
SNMP_DEFAULT_COMMUNITY=public
SNMP_PORT=161
SNMP_TIMEOUT=5

# ─────────────────────────────────────────────────────────────────────────────
# TLS — vérification des certificats devices (HTTPS LTU / UISP Power)
# ─────────────────────────────────────────────────────────────────────────────
# false par défaut car les Ubiquiti shippent un cert auto-signé.
# Mettre à true après pinning des fingerprints ou installation d'un cert CA.
TLS_VERIFY_DEVICES=false

# ─────────────────────────────────────────────────────────────────────────────
# UISP Power — API REST
# ─────────────────────────────────────────────────────────────────────────────
UISP_POWER_USERNAME=ubnt
UISP_POWER_PASSWORD=ubnt
UISP_POWER_PORT=443

# ─────────────────────────────────────────────────────────────────────────────
# LTU Rocket — API HTTP (CCQ, signal, rates)
# ─────────────────────────────────────────────────────────────────────────────
LTU_API_USERNAME=ubnt
LTU_API_PASSWORD=ubnt
LTU_API_PORT=443

# ─────────────────────────────────────────────────────────────────────────────
# LTU LR — SSH (sonde transit)
# ─────────────────────────────────────────────────────────────────────────────
LTU_LR_SSH_USERNAME=ubnt
LTU_LR_SSH_PASSWORD=
LTU_LR_SSH_PORT=22

# ─────────────────────────────────────────────────────────────────────────────
# Switch — supervision des ports
# ─────────────────────────────────────────────────────────────────────────────
SWITCH_ROCKET_PORT_INDEX=0   # ifIndex SNMP du port relié au Rocket (0 = désactivé)
SWITCH_MAX_PORTS=16
SWITCH_PORT_MIN_SPEED_MBPS=1000

# ─────────────────────────────────────────────────────────────────────────────
# Seuils — lien radio (Rocket / LR)
# ─────────────────────────────────────────────────────────────────────────────
SIGNAL_WARNING_DBM=-70
SIGNAL_CRITICAL_DBM=-80
CCQ_WARNING_PCT=75
CCQ_CRITICAL_PCT=50
CINR_WARNING_DB=20
CINR_CRITICAL_DB=10

# Capacité du lien (% de la capacité idéale)
CAPACITY_LOW_WARNING_PCT=30
CAPACITY_LOW_CRITICAL_PCT=15

# Taux d'erreurs RX/TX (errors / total bytes, %)
RX_TX_ERROR_WARNING_PCT=1.0
RX_TX_ERROR_CRITICAL_PCT=5.0

# Anti-flap — cycles consécutifs en mauvais état avant alerte (0 = immédiat)
SIGNAL_FAILURE_THRESHOLD=2
CINR_FAILURE_THRESHOLD=2
CCQ_FAILURE_THRESHOLD=2
CAPACITY_FAILURE_THRESHOLD=3
ERROR_FAILURE_THRESHOLD=2
RADIO_DEGRADED_FAILURE_THRESHOLD=2
THROUGHPUT_ANOMALY_FAILURE_THRESHOLD=3

# Détection chute de débit vs moyenne mobile (EMA)
THROUGHPUT_ANOMALY_DROP_PCT=50.0   # alerte si rate < EMA × (1 - drop_pct/100)
THROUGHPUT_ANOMALY_MIN_MBPS=1.0    # ignore si EMA < ce seuil (lien quasi-idle)

# ─────────────────────────────────────────────────────────────────────────────
# Seuils — UISP Power (batterie)
# ─────────────────────────────────────────────────────────────────────────────
BATTERY_WARNING_PCT=25
BATTERY_CRITICAL_PCT=10

# ─────────────────────────────────────────────────────────────────────────────
# Auto-discovery — détection LR disparu
# ─────────────────────────────────────────────────────────────────────────────
# Un LR auto-découvert est considéré disparu s'il n'apparaît plus comme peer
# d'aucun Rocket pendant STALE_LR_MINUTES minutes.
STALE_LR_CHECK_INTERVAL_MINUTES=5
STALE_LR_MINUTES=10
